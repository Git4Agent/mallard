{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mallard",
  "version": "0.1.0",
  "identifier": "com.hequ.agent-sync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mallard",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0RkM2MjJCRTkwRjIyNjEKUldSaElnL3BLMkw4TktGNW1zQ05yN2FHaUxJZFRzNWJMcmtOM3FYbWVQMGxEZXVCbmE0UXVmdm0K",
      "endpoints": [
        "https://api.mallard-ai.com/v1/releases/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
